APP_ENV=local
API_HOST=0.0.0.0
API_PORT=5001

# Postgres
POSTGRES_DSN=postgresql+asyncpg://adk:adk@localhost:5432/adk

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=adk
MONGO_MEMORY_COLLECTION=memory_chunks
MONGO_PROFILE_COLLECTION=user_profiles
MONGO_VECTOR_INDEX=memory_vector_index

# Embeddings
EMBEDDING_PROVIDER=azure_openai
EMBEDDING_DIM=384
OPENAI_API_KEY=

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_KEY=
AZURE_OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
AZURE_OPENAI_API_VERSION=2024-06-01

# Vertex AI (if embedding provider uses Vertex in the future)
VERTEX_PROJECT=
VERTEX_LOCATION=

# Vector Search
VECTOR_SCORE_THRESHOLD=0.75
VECTOR_TOP_K=8

# Memory chunking (token-based)
MEMORY_CHUNK_MODE=hybrid
MEMORY_CHUNK_MAX_TOKENS=600
MEMORY_CHUNK_OVERLAP_TOKENS=100
MEMORY_CHUNK_SEMANTIC_SIMILARITY_THRESHOLD=0.78
MEMORY_CHUNK_SEMANTIC_MIN_TOKENS=250

# State delta
TEMP_STATE_PREFIX=temp:

API_ENDPOINT=
API_KEY=
 